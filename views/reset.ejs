<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>SMC Web-Assist | Reset Password</title>
	<link rel="icon" type="image/x-icon" href="/img/smcLogo.ico">
	<link href="/bootstrap/bootstrap-5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
	<link rel="stylesheet" type="text/css" href="/css/stylesheet.css">

</head>
<body>
	<nav class="navbar d-flex justify-content-center p-3" id="navBar">
		<a class="text-dark navbar-brand ps-3 " href="/smc-webassist/home">SMC Web Assist</a>
	</nav>
	
	<div class="position-relative p-0" id="modalForgot">
		<div class="position-absolute top-50 start-50 translate-middle w-100 rounded shadow border">
			<div class="d-flex flex-column text-center rounded bg-light p-2">
				<h5 class="mt-5"> Reset Password</h5>
				<p> Reset password for <strong id="userNameText">User</strong>.</p>
				<form action="/smc-webassist/reset-password/update" method="POST" class="needs-validation d-flex flex-column" novalidate>

					<div class="mt-5 justify-content-center d-flex">
						
							<i class="fa-solid fa-lock pt-2 me-2" style="font-size: 1.0em;"></i>
						
							<input type="password" class="pb-0 form-control rounded-0 border-2 border-start-0 border-top-0 border-end-0" 
							style="width: 70%;" 
							id="userPass" 
							placeholder="New Password" 
							onkeyup="showPassIcon()" 
							name="userPass" 
							required pattern="[a-zA-Z0-9]+" maxlength="20" title="Password">
						
					</div>
					<div class="mt-3 mb-3 justify-content-center d-flex">
						
							<i class="fa-solid fa-lock pt-2 me-2" style="font-size: 1.0em;"></i>
						
							<input type="password" class="pb-0 form-control rounded-0 border-2 border-start-0 border-top-0 border-end-0" 
							style="width: 70%;" 
							id="userPassConfirm" 
							placeholder="Confirm New Password" 
							onkeyup="showPassIcon()" 
							name="userPassConfirm" 
							required pattern="[a-zA-Z0-9]+" maxlength="20" title="Confirm Password">
						
					</div>
					<div class="mt-3 mb-3 justify-content-center d-flex">
						<input class="p-0 me-2" type="checkbox" onclick="showPass()">Show Password
					</div>
					
					<div class="mt-4 mb-4 justify-content-center d-flex">
						
							<button class="btn btn-outline-success ps-5 pe-5" id="signBtn" type="submit">Reset</button>
						
					</div>
				</form>
			</div>
		</div>
	</div>

